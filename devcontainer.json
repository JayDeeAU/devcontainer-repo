{
  "name": "Modern Python + Next.js Development Environment",
  "workspaceFolder": "/share/DevelopmentProjects/${localWorkspaceFolderBasename}",
  "workspaceMount": "source=/share/DevelopmentProjects,target=/share/DevelopmentProjects,type=bind,consistency=cached",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "USERNAME": "${localEnv:USER}"
    }
  },
  "runArgs": [
    "--name",
    "devcontainer_${localWorkspaceFolderBasename}",
    "--hostname",
    "devcontainer-${localWorkspaceFolderBasename}",
    "--dns",
    "192.168.2.1",
    "--dns",
    "100.100.100.100",
    "--dns-search",
    "mule-mercat.ts.net"
  ],
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": false,
      "username": "none",
      "upgradePackages": true,
      "nonFreePackages": false
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22",
      "nodeGypDependencies": true
    },
    "ghcr.io/devcontainers-extra/features/poetry:2": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "enableNonRootDocker": true,
      "moby": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "./features/codemian-standards": {
      "installFonts": false,
      "installNetworkTools": true,
      "installDevTools": true
    },
    "./features/host-ssh-access": {},
    "./features/extension-manager": {
      "autoSync": true,
      "watchInterval": "30",
      "backupExtensions": true
    },
    "./features/claude-code": {
      "installLatest": true,
      "createAliases": true
    }
  },
  
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "github.copilot",
        "github.copilot-chat",
        "github.vscode-pull-request-github",
        "ms-azuretools.vscode-containers",
        "ms-python.autopep8",
        "ms-python.black-formatter",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.vscode-python-envs",
        "ms-vscode-remote.remote-containers",
        "ms-vscode.vscode-typescript-next"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/python/current/bin/python",
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/usr/bin/zsh",
            "args": ["-l"]
          }
        }
      }
    }
  },
  
  "remoteUser": "${localEnv:USER}",
  "containerUser": "${localEnv:USER}",

  "containerEnv": {
    "DOTFILES_REPO": "https://github.com/JayDeeAU/dotfiles.git",
    "DEVCONTAINER_WORKSPACE": "${containerWorkspaceFolder}"
  },

  "updateContentCommand": "chmod +x .devcontainer/scripts/install-dependencies.sh && .devcontainer/scripts/install-dependencies.sh",
  "postCreateCommand": {
    "dotfiles": "chmod +x .devcontainer/scripts/setup-environment.sh && .devcontainer/scripts/setup-environment.sh",
    "vscode": "mkdir -p .vscode && [ -f .devcontainer/tasks.json ] && cp .devcontainer/tasks.json .vscode/tasks.json || true",
    "renders": "[ -x claude-base/base-init.sh ] && claude-base/base-init.sh --refresh || true"
  },
  "postStartCommand": {
    "docker": "docker context use default 2>/dev/null || true",
    "split-dns": "chmod +x .devcontainer/scripts/start-split-dns.sh && .devcontainer/scripts/start-split-dns.sh"
  },

  "portsAttributes": {
    "8800": { "label": "Frontend", "onAutoForward": "notify" },
    "8810": { "label": "Backend API", "onAutoForward": "notify" },
    "8830": { "label": "Redis", "onAutoForward": "ignore" }
  },

  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    "source=${localEnv:HOME}/.ssh,target=/home/${localEnv:USER}/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/${localEnv:USER}/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude.json,target=/home/${localEnv:USER}/.claude.json,type=bind,consistency=cached",
    "source=/etc/hosts,target=/etc/hosts.host,type=bind,readonly"
  ]
}